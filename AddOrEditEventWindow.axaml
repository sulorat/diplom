<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:CompileBindings="False"
        x:Class="diplom.AddOrEditEventWindow"
        Title="AddOrEditEventWindow">
        <Border BorderBrush="Aquamarine" BorderThickness="5">
                <StackPanel HorizontalAlignment="Center">
                        <TextBlock Name="TitleTextBlock" HorizontalAlignment="Center"/>
                        <StackPanel Margin="0,25" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                        <TextBlock Text="Оборудование" Margin="0,5,5,5"/>
                                        <ComboBox Name="EquipComboBox"   Margin="5,5,0,5"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                        <TextBlock Text="Описание проблемы" Margin="0,5,5,5"/>
                                        <TextBox Name="DescriptionTextBox" Margin="5,5,0,5"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                        <TextBlock Text="Состояние" Margin="0,5,5,5"/>
                                        <ComboBox Name="StatusComboBox"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                        <TextBlock Text="Дата проверки" Margin="0,5,5,5"/>
                                        <DatePicker Name="DateCheckPicker"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,10" HorizontalAlignment="Center">
                                        <Button Margin="0,5,5,0" Name="SaveButton" Content="Сохранить" Click="SaveButton_OnClick"/>
                                        <Button Margin="5,5,0,0" Name="BackButton" Content="Назад"  Click="BackButton_OnClick"/>
                                </StackPanel>
                                <TextBlock Name="ErrorTextBlock" Margin="20,0,0,0"/>
                        </StackPanel>
                </StackPanel>
        </Border>
</Window>
